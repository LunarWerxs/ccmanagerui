{
  "name": "ccmanagerui",
  "private": true,
  "version": "0.11.0",
  "license": "MIT",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "bun run --parallel --workspaces dev",
    "dev:server": "bun run --cwd server dev",
    "dev:web": "bun run --cwd web dev",
    "build": "bun run --cwd web build",
    "compile": "bun build --compile --outfile=tmp/ccmanagerui server/src/main.ts",
    "start": "bun run --cwd server start",
    "mcp": "bun server/src/mcp.ts",
    "screenshots": "bun scripts/screenshots/capture.mjs",
    "check": "biome check . && bun run --cwd web check:i18n && bun run check:kit",
    "check:kit": "node ../lunarwerx-ui/sync.mjs --check --app ccmanagerui",
    "lint": "biome check .",
    "typecheck": "bun run --cwd web typecheck && bun run --cwd server typecheck",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5"
  }
}
