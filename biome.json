{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/data",
      "!.arkitect/reports",
      "!tmp",
      "!**/*.gen.ts",
      "!**/*.css",
      "!**/*.mjs",
      "!**/*.d.mts",
      "!**/*.d.ts",
      "!**/components/ui",
      "!**/shell",
      "!**/lib/utils.ts",
      "!**/lib/theme.ts",
      "!**/lib/httpClient.ts",
      "!**/lib/i18n-core.ts",
      "!**/lib/relativeTime.ts",
      "!**/lib/useSelfUpdate.ts",
      "!**/lib/tooltip-config.ts",
      "!**/lib/content-inset.ts",
      "!**/lib/grip-drag.ts",
      "!**/tests/server-lib"
    ]
  },
  "css": { "formatter": { "enabled": false }, "linter": { "enabled": false } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noExplicitAny": "off" },
      "style": { "noNonNullAssertion": "off" }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "semicolons": "asNeeded" }
  },
  "overrides": [
    {
      "includes": ["**/*.vue"],
      "linter": {
        "rules": {
          "style": { "useVueMultiWordComponentNames": "off" },
          "correctness": { "noUnusedImports": "off", "noUnusedVariables": "off" }
        }
      }
    }
  ]
}
